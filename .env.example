# ═══════════════════════════════════════════════════════════════════════════════
# AWS Architect Agent — Configuration
# Copier ce fichier en .env et renseigner les valeurs
# Ne JAMAIS committer le fichier .env
# ═══════════════════════════════════════════════════════════════════════════════

# ─── MODÈLES OLLAMA ─────────────────────────────────────────────────────────
# Changer ici pour swapper un modèle sans rebuilder l'image
# Modèles disponibles après ollama pull :
#   devstral-small-2:24b  → génération IaC, code Python
#   minimax-m1            → à vérifier : ollama search minimax
#   llama3.1:70b          → alternative open source
#   codellama:34b         → alternative code

MODEL_ARCHITECT=minimax-m2.7:cloud
MODEL_IAC=devstral-small-2:24b
MODEL_REPORT=devstral-small-2:24b
MODEL_EXECUTOR=devstral-small-2:24b

# ─── GITHUB ─────────────────────────────────────────────────────────────────
# Créer un Personal Access Token sur https://github.com/settings/tokens
# Permissions requises : repo (full), workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=votre-org/votre-repo

# ─── AWS (pour strands_tools AWS natif) ─────────────────────────────────────
# En local avec LocalStack, les valeurs fictives suffisent
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=eu-west-1

# ─── LOCALSTACK ─────────────────────────────────────────────────────────────
# Services à activer (liste complète : https://docs.localstack.cloud/references/coverage/)
LOCALSTACK_SERVICES=s3,iam,lambda,dynamodb,ec2,sts,cloudformation

# LocalStack Pro (laisser vide si Community Edition)
LOCALSTACK_AUTH_TOKEN=

# Mode debug LocalStack (0=off, 1=on)
LOCALSTACK_DEBUG=0

# ─── CONTEXTE UTILISATEUR (optionnel) ───────────────────────────────────────
# Injecté dans les prompts agents pour personnaliser les réponses
USER_CONTEXT="Architecte AWS expert Terraform, projets entreprise, DDD, Python 3.13+"
